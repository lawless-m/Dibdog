{

  "parquet_dir": "\\\\rivsprod02\\RI Services\\Outputs\\Parquets",

  "parquets": [

    {

      "name": "analysis",

      "path": "em/analysis.parquet",

      "persistent": true,

      "description": "Actual Sales data. at the invoiced Orders Line Level Data. When aggregating sales this is the preferred table, not joining orderh to orderi - not all orders are actually finalized and invoiced, things can go wrong between an order and the invoice such as stock being unavailable or damaged in transit. Revenue is only correct in the analysis table"

    },

    {

      "name": "orderh",

      "path": "em/orderh.parquet",

      "persistent": true,

      "description": "This is not the sales data, just the ordera placed. Contains Order header records, orders are placed but may or may not be fulfilled, only orders with an ohinvref were delivered"

    },

    {

      "name": "orderi",

      "path": "em/orderi.parquet",

      "persistent": true,

      "description": "Order item details, this is what was ordered, not what was sold"

    },

    {

      "name": "product",

      "path": "em/product.parquet",

      "persistent": true,

      "description": "Current Product offering, although some products in this table are discontinued but remain present for lookups"

    },

    {

      "name": "prodgrp",

      "path": "em/prodgrp.parquet",

      "persistent": true,

      "description": "Product groups. Product groups form a hierachy. Code E5 is Biscuits and E510 is chocolate biscuits. To compare broad categories use the first two characters of product.group"

    },

    {

      "name": "customer",

      "path": "em/customer.parquet",

      "persistent": true,

      "description": "Customer details"

    },

    {

      "name": "rigeographic",

      "path": "em/rigeographic.parquet",

      "persistent": true,

      "description": "Ramsden International (RI) Geographic - how the company divides territory, region and country text based on codes"

    }

  ],

