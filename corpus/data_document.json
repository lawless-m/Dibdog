        ],

        "columns": {

          "code": {

            "description": "Product Group Code, these form a hierarchy, e.g. ('E5', 'Biscuits') and ('E510', 'Choc Biscuit Bars') are both in 'E5', so when trying to match a product group and a product we must be mindful of that. So if someone ask for 'product category biscuits' then we should match on left(product.group,2) = prodgrp.code and prodgrp.desc='Biscuits'",

            "businessName": "Product Group Code",

            "dbisamName": "Code"

          },

          "desc": {

            "description": "Description of the product group",

