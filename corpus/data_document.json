      },

      "rigeographic": {

        "primaryKey": [

          "regioncode"

        ],

        "columns": {

          "regioncode": {

            "description": "a six character code 'TTCCRR' which encodes territory TT, country CC and region CC, each a subset of the other - territories have countries, countries have regions. Some regioncodes end in AA meaning the country code was the only meaningful distinction so known as all while France as France Alps, France East Middle, France North East, France North and more",

            "businessName": "terrcode",

            "dbisamName": "RegionCode"

          },

          "regiondesc": {

            "description": "Some regioncodes end in AA meaning the country code was the only meaningful distinction so the region is known as All form example 'Italy All' while France has France Alps, France East Middle, France North East, France North and more",

            "businessName": "region",

            "dbisamName": "RegionDesc"

          },

          "countrycode": {

            "description": "a two character code 'CC' which is the ISO country code, part of a territory and contains regions.",

            "businessName": "country code",

            "dbisamName": "CountryCode"

          },

          "riterritorycode": {

            "description": "a two character code 'TT' which is a Ramsden International (our company) code for territories e.g. AI which is Atlantic Islands",

            "businessName": "territory code",

            "dbisamName": "RITerritoryCode"

          },

          "continentname": {

            "description": "the continent name for this regioncode e.g. 'South America' - doesn't necessarily strictly follow convention",

            "businessName": "continent",

            "dbisamName": "Continentname"

          },

          "rinewanalysisterr": {

            "description": "a free text description of the territory e.g. Atlantic Islands describes the code AI",

            "businessName": "territory",

            "dbisamName": "RINewAnalysisTerr"

          },

          "countryname": {

            "description": "the country name in which this regioncode sits e.g. Falkland Islands",

            "businessName": "country",

            "dbisamName": "CountryName"

          },

          "riterritorydesc": {

            "description": "a free text description of the territory e.g. Atlantic Islands describes the code AI but these were renamed but the old codes kept for reference - I'm not sure of how to choose, best to just use rinewanalysisterr instead",

            "businessName": "old territory",

            "dbisamName": "RITerritoryDesc"

          }

        }

