select_statement(all_rows,[qualified(identifier('CUSTOMER'),identifier('CODE')),qualified(identifier('CUSTOMER'),identifier('CPYNAME')),qualified(identifier('CUSTOMER'),identifier('TERR')),qualified(identifier('CUSTOMER'),identifier('UF_ACCHAND'))],[table(identifier('CUSTOMER'),no_alias)],[where(or(like(qualified(identifier('CUSTOMER'),identifier('CODE')),string_literal('4%')),like(qualified(identifier('CUSTOMER'),identifier('CODE')),string_literal('9%'))))]).
