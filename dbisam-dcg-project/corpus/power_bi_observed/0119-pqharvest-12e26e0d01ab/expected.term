select_statement(all_rows,[identifier(ref),identifier(custcode),identifier('INPUTDATE'),identifier(ohinvref),qualified(identifier(ordstat),identifier(datedone))],[joined(left,table(identifier(orderh),no_alias),table(identifier(ordstat),no_alias),eq(qualified(identifier(orderh),identifier(ref)),qualified(identifier(ordstat),identifier(ref))))],[where(and(and(and(like(identifier(ohinvref),string_literal('1%')),eq(identifier(valnet),integer_literal(0))),eq(qualified(identifier(ordstat),identifier(lineno)),integer_literal(72))),is_null(qualified(identifier(ordstat),identifier(datedone)))))]).
