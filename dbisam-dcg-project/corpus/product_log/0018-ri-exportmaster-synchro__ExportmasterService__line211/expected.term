select_statement(all_rows,[aliased(function_call('MAX',[qualified(identifier('JOURNAL'),identifier(jdRecNo))]),identifier(indexed_id)),aliased(qualified(identifier('QUOTEH'),identifier('REF')),identifier(quote_id)),aliased(qualified(identifier('QUOTEH'),identifier('UF_SHIPMENTREF')),identifier(shipment_id))],[joined(inner,table(identifier('QUOTEH'),no_alias),table(identifier('JOURNAL'),no_alias),eq(qualified(identifier('JOURNAL'),identifier(jdRef)),qualified(identifier('QUOTEH'),identifier('REF'))))],[where(and(and(cmp(gt,qualified(identifier('JOURNAL'),identifier(jdRecNo)),parameter(positional)),cmp(lt,qualified(identifier('JOURNAL'),identifier(jdRecNo)),parameter(positional))),cmp(ne,qualified(identifier('QUOTEH'),identifier('INSTATUS')),integer_literal(1)))),group_by([identifier(quote_id)])]).
