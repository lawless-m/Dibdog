select_into(identifier('MAXSPDDATEEFFS'),select_statement(all_rows,[qualified(identifier('PRICDETL'),identifier('SpdLink')),aliased(function_call('MAX',[qualified(identifier('PRICDETL'),identifier('SpdDateEff'))]),identifier(maxSpdDateEff))],[table(identifier('PRICDETL'),no_alias)],[where(and(cmp(le,qualified(identifier('PRICDETL'),identifier('SpdDateEff')),parameter(positional)),or(eq(qualified(identifier('PRICDETL'),identifier('SpdDateExp')),string_literal('1899-12-30')),cmp(ge,qualified(identifier('PRICDETL'),identifier('SpdDateExp')),parameter(positional))))),group_by([qualified(identifier('PRICDETL'),identifier('SpdLink'))])])).
