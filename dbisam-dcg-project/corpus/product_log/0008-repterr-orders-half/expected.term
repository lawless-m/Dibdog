select_statement(all_rows,[string_literal(orders),identifier(custcode),function_call('SUM',[identifier(valnetbase)])],[table(identifier(orderh),no_alias)],[where(and(and(and(eq(identifier(instatus),integer_literal(1)),is_null(identifier(ohinvref))),eq(extract('MONTH',identifier(uf_shipout)),extract('MONTH',function_call('CURRENT_DATE',[])))),eq(extract('YEAR',identifier(uf_shipout)),extract('YEAR',function_call('CURRENT_DATE',[]))))),group_by([identifier(custcode)])]).
