union(select_statement(all_rows,[qualified(identifier('QUOTEI'),identifier('REF')),qualified(identifier('QUOTEI'),identifier('PRODUCT')),qualified(identifier('QUOTEI'),identifier('QUANTITY'))],[table(catalog_qualified(identifier('NISAINT_CS'),identifier('QUOTEI')),identifier('QUOTEI'))],[where(or(like(qualified(identifier('QUOTEI'),identifier('PRODUCT')),string_literal('*REPRO%')),like(qualified(identifier('QUOTEI'),identifier('PRODUCT')),string_literal('*OFSFR%'))))]),select_statement(all_rows,[qualified(identifier('ORDERI'),identifier('REF')),qualified(identifier('ORDERI'),identifier('PRODUCT')),qualified(identifier('ORDERI'),identifier('QUANTITY'))],[table(catalog_qualified(identifier('NISAINT_CS'),identifier('ORDERI')),identifier('ORDERI'))],[where(like(qualified(identifier('ORDERI'),identifier('PRODUCT')),string_literal('*REPRO%')))])).
